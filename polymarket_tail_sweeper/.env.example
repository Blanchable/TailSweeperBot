# Polymarket Tail Sweeper — Environment Configuration
#
# Copy this file to .env and fill in your credentials for live trading.
# Paper mode works without any credentials.

# Your Ethereum private key (for signing CLOB orders)
# NEVER share this key. Keep it local.
POLYMARKET_PRIVATE_KEY=

# Your funder / proxy wallet address on Polygon
POLYMARKET_FUNDER_ADDRESS=

# Signature type: 0 = EOA, 1 = POLY_GNOSIS_SAFE, 2 = POLY_PROXY
POLYMARKET_SIGNATURE_TYPE=0
